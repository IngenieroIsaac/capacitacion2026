<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Validador de Capacitación 2026 - Isaac Cruz</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        :root { --azul: #1e3a8a; --dorado: #b45309; }
        body { background-color: #f1f5f9; font-family: sans-serif; }
        .card-valid { border-left: 8px solid #22c55e; animation: slideIn 0.3s ease-out; }
        @keyframes slideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center p-4">

    <!-- Encabezado Profesional -->
    <header class="w-full max-w-2xl bg-blue-900 text-white rounded-2xl p-6 mb-6 shadow-lg text-center">
        <h1 class="text-xl md:text-2xl font-bold tracking-tight">SISTEMA DE VERIFICACIÓN QR</h1>
        <p class="text-blue-200 text-xs mt-1 uppercase tracking-widest">Ing. Isaac Cruz Miranda - Consultor</p>
    </header>

    <main class="w-full max-w-2xl">
        <!-- Panel de Búsqueda -->
        <div class="bg-white rounded-2xl shadow-sm p-6 mb-6 border border-gray-100">
            <label class="block text-gray-500 text-xs font-bold mb-2 uppercase">Validación de Constancia:</label>
            <div class="flex gap-2">
                <input type="text" id="folioInput" placeholder="Ingrese el folio (ej: PA-2026-CF-001)" 
                    class="flex-1 bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-lg font-mono uppercase focus:outline-none focus:ring-2 focus:ring-blue-500">
                <button onclick="validar()" class="bg-blue-900 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-800 transition-colors">
                    VERIFICAR
                </button>
            </div>
        </div>

        <!-- Área de Resultados -->
        <div id="resultado"></div>

        <!-- Mensaje Inicial -->
        <div id="instrucciones" class="text-center py-10 opacity-40">
            <i class="fas fa-qrcode text-6xl mb-3 text-gray-400"></i>
            <p class="text-sm">Escanee el código QR o ingrese el folio manualmente para validar la autenticidad del documento.</p>
        </div>
    </main>

    <script>
        // BASE DE DATOS RE-VERIFICADA CON TUS ARCHIVOS SUBIDOS
        const db = [
            // --- PRIMEROS AUXILIOS (City Fresko Interlomas) ---
            { f: "PA-2026-CF-001", n: "RITA MARTINEZ", c: "Primeros Auxilios", d: "13 de febrero del 2026", h: "8 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PA-2026-CF-002", n: "ANASANA CALDERON VICTORIO", c: "Primeros Auxilios", d: "13 de febrero del 2026", h: "8 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PA-2026-CF-003", n: "EDER ROMERO CHAVERO", c: "Primeros Auxilios", d: "13 de febrero del 2026", h: "8 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PA-2026-CF-004", n: "ELADIO PEREZ GORDILLO", c: "Primeros Auxilios", d: "13 de febrero del 2026", h: "8 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PA-2026-CF-005", n: "FRANCISCO JAVIER FLORES SANCHEZ", c: "Primeros Auxilios", d: "13 de febrero del 2026", h: "8 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PA-2026-CF-006", n: "GABRIEL CABALLERO TORRES", c: "Primeros Auxilios", d: "13 de febrero del 2026", h: "8 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PA-2026-CF-007", n: "ISIDRO SANCHEZ MATEO", c: "Primeros Auxilios", d: "13 de febrero del 2026", h: "8 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PA-2026-CF-008", n: "JONATHAN LOPEZ ARCOS", c: "Primeros Auxilios", d: "13 de febrero del 2026", h: "8 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PA-2026-CF-009", n: "SAID ISAI FLORES GUARNEROS", c: "Primeros Auxilios", d: "13 de febrero del 2026", h: "8 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PA-2026-CF-010", n: "ANTONIO PEREZ ENRIQUEZ", c: "Primeros Auxilios", d: "13 de febrero del 2026", h: "8 horas", s: "Comercial City Fresko (Interlomas)" },

            // --- PREVENCIÓN DEL FUEGO (City Fresko Interlomas) ---
            { f: "PF-2026-CF-011", n: "ALBERTO VASQUEZ FERNANDEZ", c: "Prevención del Fuego", d: "24 de marzo del 2026", h: "7 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PF-2026-CF-012", n: "CRIS BERTIN DUAREZ RIVERA", c: "Prevención del Fuego", d: "24 de marzo del 2026", h: "7 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PF-2026-CF-013", n: "EDGAR ENRIQUEZ SOLANO", c: "Prevención del Fuego", d: "24 de marzo del 2026", h: "7 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PF-2026-CF-014", n: "GABRIEL ROMERO MARTINEZ", c: "Prevención del Fuego", d: "24 de marzo del 2026", h: "7 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PF-2026-CF-021", n: "RICARDO MELENDEZ ALVARADO", c: "Prevención del Fuego", d: "24 de marzo del 2026", h: "7 horas", s: "Comercial City Fresko (Interlomas)" },
            { f: "PF-2026-CF-022", n: "LUIS GUSTAVO OBREGON MARTINEZ", c: "Prevención del Fuego", d: "24 de marzo del 2026", h: "7 horas", s: "Comercial City Fresko (Interlomas)" },
            
            // --- OTROS (Jesús del Monte / Huixquilucan) ---
            { f: "PA-2026-PC001", n: "AZAEL MARCOS SALINAS", c: "Primeros Auxilios", d: "Febrero 2026", h: "8 horas", s: "Huixquilucan" },
            { f: "ER-2026-PC-007", n: "DAVID LÓPEZ CASTRO", c: "Evacuación de Inmuebles", d: "11 de abril del 2025", h: "8 horas", s: "Huixquilucan" }
        ];

        function limpiarTexto(t) {
            // Elimina espacios, guiones y convierte a mayúsculas para evitar fallos de escritura
            return t.toUpperCase().replace(/[^A-Z0-9]/g, "");
        }

        function validar() {
            const rawInput = document.getElementById('folioInput').value;
            const cleanInput = limpiarTexto(rawInput);
            const resDiv = document.getElementById('resultado');
            const instDiv = document.getElementById('instrucciones');

            if (!cleanInput) return;

            instDiv.classList.add('hidden');
            
            // Búsqueda flexible comparando solo caracteres alfanuméricos
            const registro = db.find(item => limpiarTexto(item.f) === cleanInput);

            if (registro) {
                resDiv.innerHTML = `
                    <div class="bg-white rounded-2xl shadow-xl overflow-hidden card-valid mb-6">
                        <div class="bg-green-50 px-6 py-3 border-b border-green-100 flex items-center justify-between">
                            <span class="text-green-700 font-bold text-xs"><i class="fas fa-check-circle mr-2"></i>DOCUMENTO AUTÉNTICO</span>
                            <span class="text-green-600 font-mono text-xs">${registro.f}</span>
                        </div>
                        <div class="p-6">
                            <div class="mb-4">
                                <span class="text-gray-400 text-[10px] font-bold uppercase block">Participante</span>
                                <span class="text-xl font-bold text-blue-900">${registro.n}</span>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <span class="text-gray-400 text-[10px] font-bold uppercase block">Capacitación</span>
                                    <span class="text-sm font-semibold text-gray-700">${registro.c}</span>
                                </div>
                                <div>
                                    <span class="text-gray-400 text-[10px] font-bold uppercase block">Duración</span>
                                    <span class="text-sm font-semibold text-gray-700">${registro.h}</span>
                                </div>
                                <div>
                                    <span class="text-gray-400 text-[10px] font-bold uppercase block">Fecha Emisión</span>
                                    <span class="text-sm text-gray-600">${registro.d}</span>
                                </div>
                                <div>
                                    <span class="text-gray-400 text-[10px] font-bold uppercase block">Lugar</span>
                                    <span class="text-sm text-gray-600">${registro.s}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            } else {
                resDiv.innerHTML = `
                    <div class="bg-white rounded-2xl shadow-xl p-8 border-l-8 border-red-500 text-center">
                        <i class="fas fa-times-circle text-red-500 text-5xl mb-4"></i>
                        <h2 class="text-lg font-bold text-gray-800">FOLIO INEXISTENTE</h2>
                        <p class="text-gray-500 text-sm mt-2">El folio <strong class="text-red-600">${rawInput}</strong> no coincide con nuestros registros de 2026.</p>
                        <p class="text-xs text-gray-400 mt-4 italic underline cursor-pointer" onclick="location.reload()">Intentar de nuevo</p>
                    </div>
                `;
            }
        }

        // Carga automática desde URL
        window.onload = () => {
            const urlParams = new URLSearchParams(window.location.search);
            const folioUrl = urlParams.get('folio');
            if (folioUrl) {
                document.getElementById('folioInput').value = folioUrl;
                validar();
            }
        }
    </script>
</body>
</html>
