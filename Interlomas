<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Validador de Capacitación 2026</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --azul-primario: #1A365D;
            --dorado: #A37E2C;
            --gris-fondo: #FBFBFC;
        }
        body {
            background-color: var(--gris-fondo);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .header-gradient {
            background: linear-gradient(135deg, var(--azul-primario) 0%, #2c5282 100%);
        }
        .border-dorado {
            border-color: var(--dorado);
        }
        .text-azul {
            color: var(--azul-primario);
        }
        .bg-dorado {
            background-color: var(--dorado);
        }
        .card-shadow {
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        }
        .animate-fade-in {
            animation: fadeIn 0.4s ease-out;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <!-- Header -->
    <header class="header-gradient text-white py-8 px-4 shadow-lg">
        <div class="max-w-4xl mx-auto text-center">
            <h1 class="text-3xl md:text-4xl font-bold mb-2 tracking-tight">SISTEMA DE VALIDACIÓN</h1>
            <p class="text-blue-100 opacity-90">Capacitación en Materia de Protección Civil 2026</p>
        </div>
    </header>

    <main class="flex-grow container mx-auto px-4 py-10 max-w-2xl">
        
        <!-- Search Box -->
        <div class="bg-white rounded-xl p-6 card-shadow mb-8 border-t-4 border-dorado">
            <label for="folioInput" class="block text-sm font-semibold text-gray-600 mb-2">Ingrese el Folio de la Constancia:</label>
            <div class="flex gap-2">
                <input type="text" id="folioInput" placeholder="Ej: PF-2026-CF-011" 
                    class="flex-grow px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-800 focus:outline-none uppercase">
                <button onclick="buscarFolio()" class="bg-dorado hover:bg-yellow-700 text-white px-6 py-3 rounded-lg font-bold transition-colors">
                    <i class="fas fa-search"></i>
                </button>
            </div>
            <p class="text-xs text-gray-400 mt-3 italic">* El sistema valida folios registrados para las brigadas de Interlomas.</p>
        </div>

        <!-- Result Container -->
        <div id="resultArea" class="hidden">
            <!-- Content injected by JS -->
        </div>

        <!-- Default Message -->
        <div id="defaultMessage" class="text-center py-10">
            <i class="fas fa-certificate text-gray-200 text-8xl mb-4"></i>
            <p class="text-gray-400">Esperando validación de documento...</p>
        </div>

    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 py-8">
        <div class="text-center text-gray-500 text-sm">
            <p class="font-bold text-azul text-lg uppercase tracking-wide">Ing. Isaac Cruz Miranda</p>
            <p class="text-gray-600">Consultor Externo en Protección Civil</p>
            <div class="mt-4 flex justify-center gap-4 text-xs text-gray-400">
                <span>Folios Oficiales 2026</span>
                <span>•</span>
                <span>Verificación en Tiempo Real</span>
            </div>
        </div>
    </footer>

    <script>
        // Base de datos de constancias actualizada 2026
        const constancias = [
            // PRIMEROS AUXILIOS (PA) - FEBRERO 2026
            { folio: "PA-2026-FI-001", nombre: "RITA MARTINEZ", curso: "Primeros Auxilios", fecha: "13 de febrero del 2026", duracion: "8 horas" },
            { folio: "PA-2026-FI-002", nombre: "ANASANA CALDERON VICTORIO", curso: "Primeros Auxilios", fecha: "13 de febrero del 2026", duracion: "8 horas" },
            { folio: "PA-2026-FI-003", nombre: "TANIA JAZMIN LEYVA AYALA", curso: "Primeros Auxilios", fecha: "13 de febrero del 2026", duracion: "8 horas" },
            { folio: "PA-2026-FI-004", nombre: "CRISTINO CARBAJAL CATALAN", curso: "Primeros Auxilios", fecha: "13 de febrero del 2026", duracion: "8 horas" },
            { folio: "PA-2026-FI-005", nombre: "ROSA M. PEREZ", curso: "Primeros Auxilios", fecha: "13 de febrero del 2026", duracion: "8 horas" },
            { folio: "PA-2026-FI-006", nombre: "LILIANA GONZALEZ LUNA", curso: "Primeros Auxilios", fecha: "13 de febrero del 2026", duracion: "8 horas" },
            { folio: "PA-2026-FI-007", nombre: "ISRAEL VAZQUEZ LOPEZ", curso: "Primeros Auxilios", fecha: "13 de febrero del 2026", duracion: "8 horas" },
            { folio: "PA-2026-FI-008", nombre: "YADHIRA MOCTEZUMA", curso: "Primeros Auxilios", fecha: "13 de febrero del 2026", duracion: "8 horas" },
            { folio: "PA-2026-FI-009", nombre: "SAID ISAI FLORES GUARNEROS", curso: "Primeros Auxilios", fecha: "13 de febrero del 2026", duracion: "8 horas" },
            { folio: "PA-2026-FI-010", nombre: "ANTONIO PEREZ ENRIQUEZ", curso: "Primeros Auxilios", fecha: "13 de febrero del 2026", duracion: "8 horas" },

            // PREVENCIÓN DEL FUEGO (PF) - MARZO 2026
            { folio: "PF-2026-FI-001", nombre: "ALBERTO VASQUEZ FERNANDEZ", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-FI-002", nombre: "CRIS BERTIN DUAREZ RIVERA", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-FI-003", nombre: "MARIO GUERRERO CERVANTES", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-FI-004", nombre: "LUIS ARTURO QUINTERO BAEZ", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-FI-005", nombre: "JESUS CHAMORRO TELO", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-FI-006", nombre: "PAUL ALONSO GUTIERREZ GARCIA", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-FI-007", nombre: "LUIS ALBERTO GARCIA HERNANDEZ", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-FI-008", nombre: "CHRISTIAN HERNANDEZ CRUZ", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-FI-009", nombre: "IVAN GARCIA", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-FI-010", nombre: "CESAR LOPEZ", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            
            // NUEVOS FOLIOS PREVENCIÓN DEL FUEGO (CONTINUACIÓN)
            { folio: "PF-2026-CF-011", nombre: "ALBERTO VASQUEZ FERNANDEZ", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-CF-012", nombre: "CRIS BERTIN DUAREZ RIVERA", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-CF-013", nombre: "MARIO GUERRERO CERVANTES", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-CF-014", nombre: "LUIS ARTURO QUINTERO BAEZ", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-CF-015", nombre: "JESUS CHAMORRO TELO", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-CF-016", nombre: "PAUL ALONSO GUTIERREZ GARCIA", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-CF-017", nombre: "LUIS ALBERTO GARCIA HERNANDEZ", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-CF-018", nombre: "CHRISTIAN HERNANDEZ CRUZ", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-CF-019", nombre: "IVAN GARCIA", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-CF-020", nombre: "CESAR LOPEZ", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-CF-021", nombre: "RICARDO MELENDEZ ALVARADO", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" },
            { folio: "PF-2026-CF-022", nombre: "LUIS GUSTAVO OBREGON MARTINEZ", curso: "Prevención del fuego", fecha: "24 de marzo del 2026", duracion: "7 horas" }
        ];

        function buscarFolio() {
            const input = document.getElementById('folioInput').value.trim().toUpperCase();
            const resultArea = document.getElementById('resultArea');
            const defaultMessage = document.getElementById('defaultMessage');

            if (!input) return;

            const constancia = constancias.find(c => c.folio === input);

            defaultMessage.classList.add('hidden');
            resultArea.classList.remove('hidden');

            if (constancia) {
                resultArea.innerHTML = `
                    <div class="bg-white rounded-xl card-shadow overflow-hidden border-l-8 border-green-500 animate-fade-in">
                        <div class="bg-green-50 p-4 flex items-center gap-3">
                            <i class="fas fa-check-circle text-green-500 text-2xl"></i>
                            <span class="text-green-700 font-bold uppercase tracking-tight">Documento Válido</span>
                        </div>
                        <div class="p-6">
                            <div class="grid grid-cols-1 gap-4">
                                <div>
                                    <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest mb-1">Nombre del Participante</p>
                                    <p class="text-xl font-bold text-azul">${constancia.nombre}</p>
                                </div>
                                <div class="border-t pt-4">
                                    <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest mb-1">Curso Acreditado</p>
                                    <p class="text-lg text-gray-800 font-semibold">${constancia.curso}</p>
                                </div>
                                <div class="grid grid-cols-2 gap-4 border-t pt-4">
                                    <div>
                                        <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest mb-1">Fecha de Emisión</p>
                                        <p class="text-sm font-medium text-gray-700">${constancia.fecha}</p>
                                    </div>
                                    <div>
                                        <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest mb-1">Folio de Control</p>
                                        <p class="text-sm font-mono font-bold text-dorado">${constancia.folio}</p>
                                    </div>
                                </div>
                                <div class="mt-4 bg-gray-50 p-3 rounded-lg text-center border border-gray-100">
                                    <p class="text-[11px] text-gray-500 leading-relaxed italic">
                                        Esta constancia ha sido emitida tras completar satisfactoriamente las horas de capacitación requeridas bajo la normativa de Protección Civil y está registrada ante el padrón de consultores externos.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            } else {
                resultArea.innerHTML = `
                    <div class="bg-white rounded-xl card-shadow overflow-hidden border-l-8 border-red-500 animate-fade-in">
                        <div class="bg-red-50 p-4 flex items-center gap-3">
                            <i class="fas fa-exclamation-triangle text-red-500 text-2xl"></i>
                            <span class="text-red-700 font-bold uppercase">Folio Inválido</span>
                        </div>
                        <div class="p-8 text-center">
                            <p class="text-gray-700 mb-2">El folio <span class="font-bold text-red-600">${input}</span> no se encuentra en el registro oficial de 2026.</p>
                            <p class="text-xs text-gray-400">Verifique que el folio coincida exactamente con el impreso en su constancia o intente escanear el código QR nuevamente.</p>
                        </div>
                    </div>
                `;
            }
        }

        // Lectura automática de parámetros en URL (QR Support)
        window.onload = function() {
            const urlParams = new URLSearchParams(window.location.search);
            const folio = urlParams.get('folio');
            if (folio) {
                document.getElementById('folioInput').value = folio;
                buscarFolio();
            }
        };

        // Soporte para tecla Enter
        document.getElementById('folioInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                buscarFolio();
            }
        });
    </script>
</body>
</html>
